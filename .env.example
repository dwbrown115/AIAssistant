# Copy this file to .env and set your key.

# API / model config
# Tip: keep OPENAI_API_KEY in .env.secret instead of .env.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_LOGIC_MODEL=gpt-4.1-mini
OPENAI_AGENT_MODEL=gpt-4o-mini
# Optional fallback model used by web_app.py
OPENAI_MODEL=gpt-4o-mini
# Optional: prefer the built-in navigation kernel for game/maze movement before using OpenAI.
LOCAL_NAVIGATION_KERNEL=1
# Optional: when local navigation stalls and OpenAI is available, fall back to the external models.
LOCAL_NAVIGATION_API_FALLBACK=1

# Wave 2+ kernel-managed env keys are intentionally removed from this template.
# Kernel defaults and policy knobs are managed in runtime_kernel/.

# Web app config
PORT=5050
